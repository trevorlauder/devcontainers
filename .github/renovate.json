{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "schedule": [
    "every weekend"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/src/base/devcontainer-feature\\.json/"
      ],
      "matchStrings": [
        "\"chezmoiVersion\"[\\s\\S]*?\"default\":\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "twpayne/chezmoi",
      "datasourceTemplate": "github-releases"
    }
  ],
  "packageRules": [
    {
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "github-actions"
    },
    {
      "matchManagers": [
        "mise"
      ],
      "groupName": "mise"
    },
    {
      "matchDepNames": [
        "twpayne/chezmoi"
      ],
      "groupName": "chezmoi"
    }
  ]
}
