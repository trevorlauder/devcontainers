{
  "id": "python",
  "version": "1.2.2",
  "name": "Python Feature",
  "description": "Configures Python tooling",
  "dependsOn": {
    "ghcr.io/trevorlauder/devcontainers/base:1": {}
  },
  "options": {},
  "customizations": {
    "vscode": {
      "extensions": [
        "charliermarsh.ruff"
      ],
      "settings": {
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.formatOnSave": true
        }
      }
    }
  }
}
