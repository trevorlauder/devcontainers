{
  "id": "base",
  "version": "1.1.15",
  "name": "Base Development Environment",
  "description": "Base devcontainer image layer",
  "options": {
    "timezone": {
      "type": "string",
      "default": "America/Edmonton",
      "description": "Container timezone"
    },
    "chezmoiVersion": {
      "type": "string",
      "default": "2.70.0",
      "description": "chezmoi version to install"
    },
    "username": {
      "type": "string",
      "default": "vscode",
      "description": "Username to create and use as the container user."
    }
  },
  "containerEnv": {
    "LANG": "C.UTF-8",
    "LC_ALL": "C.UTF-8",
    "DEVCONTAINER": "true",
    "SHELL": "/usr/bin/zsh",
    "EDITOR": "vi",
    "VISUAL": "vi",
    "CLAUDE_CONFIG_DIR": "/home/vscode/.claude"
  }
}
