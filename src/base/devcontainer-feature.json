{
  "id": "base",
  "version": "1.3.8",
  "name": "Base Development Environment",
  "description": "Base devcontainer image layer",
  "options": {
    "timezone": {
      "type": "string",
      "default": "America/Edmonton",
      "description": "Container timezone"
    },
    "chezmoiVersion": {
      "type": "string",
      "default": "2.70.1",
      "description": "chezmoi version to install"
    },
    "homeDirs": {
      "type": "string",
      "default": "",
      "description": "Space-separated list of directories relative to $HOME to create as the container user"
    },
    "packages": {
      "type": "string",
      "default": "",
      "description": "Space-separated list of packages to install in the container using apt-get"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "eamodio.gitlens",
        "github.vscode-pull-request-github",
        "ms-azuretools.vscode-containers",
        "ms-python.python"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "zsh": {
            "path": "zsh",
            "args": ["-l"]
          }
        }
      }
    }
  },
  "containerEnv": {
    "LANG": "C.UTF-8",
    "LC_ALL": "C.UTF-8",
    "SHELL": "/usr/bin/zsh",
    "EDITOR": "vi",
    "VISUAL": "vi"
  }
}
